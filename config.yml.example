database:
  url: "postgresql+psycopg://localhost:5432/lighthouse"
  raw_schema: "raw"
  core_schema: "core"
  analytics_schema: "analytics"

api_keys:
  congress_gov: ""          # https://api.congress.gov/sign-up/
  fec: ""                   # https://api.data.gov/signup/
  financial_modeling_prep: ""  # optional paid source

rate_limits:
  congress_api:   1.3       # req/sec (5000/hr)
  fec_api:        0.003     # req/sec (250/day handled separately)
  sec_edgar:      10.0      # req/sec
  house_watcher:  1.0       # req/sec
  senate_watcher: 1.0       # req/sec
  govinfo:        2.0       # req/sec

data:
  cache_dir: "./data"
  output_dir: "./output"
  legislators_path: "./data/legislators-current.csv"
  billstatus_xml_dir: "./data/billstatus_xml"
  bill_cache_days: 1
  disclosure_cache_days: 7

fec_warehouse:
  source_db_url: ""         # optional local bulk FEC Postgres db, e.g. postgresql+psycopg:///fec_complete?host=/tmp
  raw_dir: "./data/fec"
  cycles:
    - 2022
    - 2024
    - 2026
  prefer_local_db: true

detection:
  trade_window_days: 30
  min_holding_value: 1000
  mutual_fund_discount: 0.2
  family_holding_discount: 0.6

  rule_weights:
    vote_holding: 0.85
    trade_timing_pre: 1.00
    trade_timing_post: 0.70
    sponsorship_holding: 0.90
    committee_donor: 0.65
    family_holding: 0.75

congress:
  current: 119
  chambers:
    - house
    - senate
